{
  "name": "echonote",
  "private": true,
  "version": "5.1.0",
  "type": "module",
  "main": "dist/electron-main.js",
  "scripts": {
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "start": "electron .",
    "build:electron": "npm run build && tsc --project tsconfig.electron.json && tsc --project tsconfig.preload.json && electron-builder",
    "dev:electron": "concurrently \"npm run dev\" \"tsc --project tsconfig.electron.json --watch\" \"tsc --project tsconfig.preload.json --watch\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development npm run start\""
  },
  "dependencies": {
    "better-sqlite3": "^12.2.0",
    "dompurify": "^3.2.6",
    "i18next": "^25.4.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^15.7.3",
    "react-modern-drawer": "^1.4.0",
    "react-resizable-panels": "^3.0.5",
    "react-router-dom": "^7.8.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@testing-library/jest-dom": "^6.7.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "@vitest/ui": "^3.2.4",
    "concurrently": "^9.2.0",
    "cross-env": "^10.0.0",
    "electron": "^37.2.5",
    "electron-builder": "^26.0.12",
    "eslint": "^9.30.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "jsdom": "^26.1.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.35.1",
    "vite": "^7.0.4",
    "vitest": "^3.2.4",
    "wait-on": "^8.0.4"
  },
  "build": {
    "appId": "com.github.yorjihons.echonote",
    "files": [
      "dist/**/*",
      "dist/electron-main.js"
    ],
    "icon": "src/assets/favicon.png"
  }
}
